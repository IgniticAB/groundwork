<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Audit · {{PROJECT_NAME}}</title>
<style>
:root {
  --bg: oklch(0.985 0.005 80);
  --bg-soft: oklch(0.96 0.006 80);
  --ink: oklch(0.20 0.01 70);
  --ink-soft: oklch(0.34 0.01 70);
  --muted: oklch(0.56 0.01 70);
  --rule: oklch(0.88 0.006 80);
  --rule-soft: oklch(0.93 0.005 80);
  --code-bg: oklch(0.93 0.005 80);
  --ember: oklch(0.70 0.16 60);
  --ember-ink: oklch(0.50 0.15 55);
  --ember-soft: oklch(0.93 0.06 75);
  --rust-ink: oklch(0.45 0.16 25);
  --display: 'Bricolage Grotesque', 'Source Sans 3', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  --mono: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;
  --gutter: clamp(1rem, 3vw, 2rem);
  --ease: cubic-bezier(0.25, 1, 0.5, 1);
}
[data-theme="dark"] {
  --bg: oklch(0.18 0.01 70);
  --bg-soft: oklch(0.22 0.01 70);
  --ink: oklch(0.95 0.02 70);
  --ink-soft: oklch(0.82 0.02 70);
  --muted: oklch(0.62 0.02 70);
  --rule: oklch(0.30 0.01 70);
  --rule-soft: oklch(0.26 0.01 70);
  --code-bg: oklch(0.26 0.01 70);
  --ember-soft: oklch(0.32 0.08 75);
}
*, *::before, *::after { box-sizing: border-box; }
html, body { margin: 0; }
body {
  background: var(--bg);
  color: var(--ink);
  font-family: var(--display);
  font-size: 16px;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
}
.report {
  max-width: 1140px;
  margin: 0 auto;
  padding: clamp(1.6rem, 4vw, 2.75rem) var(--gutter) 4rem;
}
.meta {
  display: flex;
  gap: 0.8rem 1rem;
  align-items: center;
  flex-wrap: wrap;
  margin: 0 0 0.9rem;
  font-size: 0.85rem;
  color: var(--muted);
}
.kicker {
  color: var(--ember-ink);
  font-weight: 600;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  font-size: 0.78rem;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}
.kicker::before {
  content: "";
  width: 1.2rem;
  height: 1px;
  background: var(--ember);
}
.date { font-family: var(--mono); font-size: 0.82rem; }
.meta-actions { margin-left: auto; display: flex; gap: 0.4rem; flex-wrap: wrap; }
.btn-ghost {
  background: transparent;
  border: 1px solid var(--rule);
  border-radius: 999px;
  color: var(--ink-soft);
  padding: 0.32rem 0.75rem;
  font: inherit;
  font-size: 0.78rem;
  cursor: pointer;
  transition: color 180ms var(--ease), border-color 180ms var(--ease);
}
.btn-ghost:hover { color: var(--ember-ink); border-color: var(--ember); }
h1.score {
  font-family: var(--display);
  font-size: clamp(3.6rem, 9vw, 6rem);
  font-weight: 750;
  line-height: 0.95;
  letter-spacing: -0.045em;
  color: var(--ember-ink);
  margin: 0;
  font-variant-numeric: tabular-nums;
}
.score-label {
  color: var(--ink-soft);
  max-width: 42ch;
  margin: 0.5rem 0 0;
}
.score-label strong { color: var(--ink); font-weight: 600; }
.layers {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0.6rem;
  margin-top: 2rem;
}
.layer {
  padding: 0.85rem 0.95rem 0.9rem;
  border: 1px solid var(--rule);
  border-radius: 8px;
  background: var(--bg);
  display: grid;
  gap: 0.2rem;
}
.layer.is-weighted { border-color: var(--ember); }
.layer-name {
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 600;
}
.layer.is-weighted .layer-name { color: var(--ember-ink); }
.layer-score {
  font-family: var(--display);
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1;
  color: var(--ink);
  font-variant-numeric: tabular-nums;
}
.layer-score .out-of {
  font-size: 0.78rem;
  font-weight: 500;
  color: var(--muted);
  margin-left: 0.15rem;
}
.layer-evidence { font-size: 0.82rem; color: var(--ink-soft); line-height: 1.45; }
@media (max-width: 720px) { .layers { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px) { .layers { grid-template-columns: 1fr; } }

.grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 320px;
  gap: clamp(1.5rem, 3vw, 2.5rem);
  margin-top: clamp(2rem, 4vw, 3rem);
}
@media (max-width: 980px) {
  .grid { grid-template-columns: 1fr; }
  .panel { order: 2; position: static !important; max-height: none !important; }
}

h2 {
  font-family: var(--display);
  font-size: 1.3rem;
  font-weight: 700;
  letter-spacing: -0.015em;
  margin: 0 0 1rem;
}

.group { margin-bottom: 1.75rem; }
.group-head {
  display: flex;
  align-items: baseline;
  gap: 0.7rem;
  margin: 1.4rem 0 0.6rem;
  padding-bottom: 0.4rem;
  border-bottom: 1px solid var(--rule-soft);
}
.group-head h3 {
  font-family: var(--display);
  font-size: 1rem;
  font-weight: 650;
  margin: 0;
  letter-spacing: -0.005em;
}
.group-head .gloss { font-size: 0.82rem; color: var(--muted); }

.finding {
  padding: 0.85rem 0;
  border-top: 1px solid var(--rule-soft);
}
.finding:first-child { border-top: none; }
.finding[data-severity="P0"] {
  padding: 1rem 1.1rem;
  border: 1px solid var(--rule);
  background: var(--bg-soft);
  border-radius: 8px;
  margin-bottom: 0.6rem;
}
.finding[data-decided="true"] { opacity: 0.7; }

.f-head {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 0.7rem;
  align-items: baseline;
}
.tag {
  font-family: var(--mono);
  font-size: 0.7rem;
  letter-spacing: 0.05em;
  padding: 0.18rem 0.5rem;
  border-radius: 999px;
  font-weight: 650;
  align-self: start;
  margin-top: 0.18rem;
}
.tag[data-severity="P0"] { color: oklch(0.97 0.01 80); background: var(--rust-ink); }
.tag[data-severity="P1"] { color: var(--ink); background: var(--ember-soft); border: 1px solid var(--ember); }
.tag[data-severity="P2"] { color: var(--ink-soft); background: var(--bg-soft); border: 1px solid var(--rule); }
.f-title { font-weight: 600; color: var(--ink); margin: 0; line-height: 1.4; }
.f-loc {
  font-family: var(--mono);
  font-size: 0.76rem;
  color: var(--muted);
  max-width: 30ch;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  direction: rtl;
  text-align: right;
}

.f-evidence { margin: 0.5rem 0 0; }
.f-evidence summary {
  cursor: pointer;
  font-size: 0.82rem;
  color: var(--muted);
  list-style: none;
  display: inline-flex;
  gap: 0.3rem;
  align-items: center;
}
.f-evidence summary::-webkit-details-marker { display: none; }
.f-evidence summary::before {
  content: "▸";
  font-size: 0.6em;
  transition: transform 200ms var(--ease);
}
.f-evidence[open] summary::before { transform: rotate(90deg); }
.f-evidence pre {
  margin: 0.5rem 0 0;
  padding: 0.7rem 0.85rem;
  background: var(--code-bg);
  color: var(--ink);
  border-radius: 5px;
  font-family: var(--mono);
  font-size: 0.82rem;
  line-height: 1.5;
  overflow-x: auto;
  white-space: pre-wrap;
  word-break: break-word;
}
.f-hint { margin: 0.45rem 0 0; font-size: 0.85rem; color: var(--ink-soft); }

.controls {
  display: flex;
  gap: 0.35rem;
  margin-top: 0.7rem;
  flex-wrap: wrap;
}
.ctl {
  font: inherit;
  font-size: 0.82rem;
  padding: 0.34rem 0.85rem;
  border-radius: 999px;
  border: 1px solid var(--rule);
  background: var(--bg);
  color: var(--ink-soft);
  cursor: pointer;
  transition: color 180ms var(--ease), border-color 180ms var(--ease), background 180ms var(--ease);
}
.ctl:hover { color: var(--ember-ink); border-color: var(--ember); }
.ctl[aria-pressed="true"] {
  color: var(--ink);
  background: var(--ember-soft);
  border-color: var(--ember);
  font-weight: 600;
}
@media (pointer: coarse) { .ctl { padding: 0.5rem 1rem; min-height: 40px; } }

.f-detail { margin-top: 0.6rem; display: none; }
.f-detail.is-open { display: block; }
.f-detail label {
  display: block;
  font-size: 0.8rem;
  color: var(--ink-soft);
  margin-bottom: 0.3rem;
  font-weight: 500;
}
.f-detail input, .f-detail textarea {
  width: 100%;
  font: inherit;
  font-family: var(--display);
  font-size: 0.92rem;
  padding: 0.5rem 0.7rem;
  border: 1px solid var(--rule);
  border-radius: 6px;
  background: var(--bg);
  color: var(--ink);
  resize: vertical;
}
.f-detail textarea { min-height: 4rem; }
.f-detail input:focus, .f-detail textarea:focus {
  outline: none;
  border-color: var(--ember);
  box-shadow: 0 0 0 3px var(--ember-soft);
}

.panel {
  position: sticky;
  top: 1.5rem;
  align-self: start;
  border: 1px solid var(--rule);
  background: var(--bg-soft);
  border-radius: 10px;
  padding: 1.1rem 1.15rem 1.2rem;
  display: grid;
  gap: 0.9rem;
  max-height: calc(100vh - 3rem);
}
.panel-head { display: flex; justify-content: space-between; align-items: baseline; gap: 0.5rem; }
.panel-head h2 { margin: 0; font-size: 1rem; font-weight: 700; }
.counter { font-family: var(--mono); font-size: 0.76rem; color: var(--muted); }
.actions {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  gap: 0.45rem;
  overflow-y: auto;
  max-height: 42vh;
}
.actions:empty::before {
  content: "Pick Fix, Defer, or Dismiss on a finding.";
  font-size: 0.85rem;
  color: var(--muted);
  display: block;
  padding: 0.4rem 0;
}
.action {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 0.5rem;
  padding: 0.55rem 0.7rem;
  background: var(--bg);
  border: 1px solid var(--rule);
  border-radius: 7px;
  font-size: 0.85rem;
}
.action-kind {
  font-family: var(--mono);
  font-size: 0.68rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 600;
  align-self: start;
  padding-top: 0.18rem;
}
.action-body { color: var(--ink-soft); line-height: 1.4; min-width: 0; }
.action-body strong { color: var(--ink); font-weight: 600; }
.action-body .a-file {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--muted);
  margin-top: 0.15rem;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.action-body .a-res { margin-top: 0.25rem; color: var(--ink); }
.action-body .a-res.is-note { font-style: italic; color: var(--ink-soft); }
.action-undo {
  align-self: start;
  background: none;
  border: none;
  color: var(--muted);
  font: inherit;
  font-size: 0.74rem;
  cursor: pointer;
  padding: 0;
}
.action-undo:hover { color: var(--rust-ink); }

.gen {
  font: inherit;
  font-family: var(--display);
  font-size: 0.95rem;
  font-weight: 650;
  padding: 0.65rem 1rem;
  background: var(--ember);
  color: oklch(0.18 0.01 70);
  border: none;
  border-radius: 8px;
  cursor: pointer;
  transition: opacity 200ms var(--ease), transform 120ms var(--ease);
}
.gen:disabled { opacity: 0.42; cursor: not-allowed; }
.gen:not(:disabled):active { transform: translateY(1px); }
.hint {
  margin: 0;
  font-family: var(--mono);
  font-size: 0.74rem;
  color: var(--muted);
  text-align: center;
  word-break: break-all;
}

:focus-visible { outline: 2px solid var(--ember); outline-offset: 2px; }

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation: none !important; transition: none !important; }
}

@media print {
  .meta-actions, .controls, .panel, .f-detail { display: none !important; }
  .grid { grid-template-columns: 1fr; gap: 0; }
  .report { padding: 0; max-width: none; }
  .finding[data-severity="P0"] { background: none; border-color: #555; }
  a { text-decoration: underline; color: inherit; }
  body { background: white; }
}
</style>
</head>
<body>
<main class="report">
  <header>
    <p class="meta">
      <span class="kicker">{{PROJECT_NAME}}</span>
      <span class="date">{{AUDIT_DATE}}</span>
      <span class="meta-actions">
        <button class="btn-ghost" type="button" data-print>Print</button>
        <button class="btn-ghost" type="button" data-theme-toggle>Dark mode</button>
      </span>
    </p>
    <h1 class="score" aria-label="Overall maturity score">{{OVERALL_SCORE}}</h1>
    <p class="score-label"><strong>Overall maturity</strong> across the five context layers. Project layer weighted 2×.</p>
    <div class="layers" id="layers"></div>
  </header>

  <div class="grid">
    <section aria-label="Findings">
      <h2 id="findings-h">Findings</h2>
      <div id="findings"></div>
    </section>
    <aside class="panel" aria-label="Remediation plan">
      <div class="panel-head">
        <h2>Your plan</h2>
        <span class="counter" id="counter">0 of 0 decided</span>
      </div>
      <ol class="actions" id="actions-list"></ol>
      <button class="gen" type="button" id="gen" disabled>Generate remediation plan</button>
      <p class="hint" id="hint">audit-remediation-{{AUDIT_DATE}}.md</p>
    </aside>
  </div>
</main>

<script type="application/json" id="m">{{META_JSON}}</script>
<script type="application/json" id="l">{{LAYERS_JSON}}</script>
<script type="application/json" id="f">{{FINDINGS_JSON}}</script>
<script>
(function(){
function p(id,fb){try{return JSON.parse(document.getElementById(id).textContent||'null')??fb}catch{return fb}}
var meta=p('m',{}),layers=p('l',[]),findings=p('f',[]);

// per-rule action kind for the generated remediation.md
function kindFor(r){
  if(r==='agents-md-vague-rules'||r==='agents-md-duplication')return'anchor';
  if(r==='verification-command-missing')return'add-or-remove-script';
  if(r==='oversized-claude-md'||r==='skill-oversized')return'split-or-move';
  if(r==='skill-broken-link')return'create-or-fix-link';
  if(r==='skill-missing-frontmatter')return'add-frontmatter';
  if(r==='skill-vague-description')return'rewrite-description';
  if(r==='missing-verification')return'populate-section';
  return'review';
}

// layers
var lRoot=document.getElementById('layers');
layers.forEach(function(L){
  var el=document.createElement('div');
  el.className='layer'+(L.weighted?' is-weighted':'');
  el.innerHTML='<div class="layer-name"></div><div class="layer-score"><span></span><span class="out-of">/5</span></div><div class="layer-evidence"></div>';
  el.querySelector('.layer-name').textContent=L.name;
  el.querySelector('.layer-score span').textContent=String(L.score);
  el.querySelector('.layer-evidence').textContent=L.evidence||'';
  lRoot.appendChild(el);
});

// findings
var groups={P0:[],P1:[],P2:[]};
findings.forEach(function(f){(groups[f.severity]||groups.P2).push(f)});
var glosses={P0:'Fix before next agent session.',P1:'Fix this sprint.',P2:'Backlog.'};
var decisions=new Map(),fEls=new Map(),fRoot=document.getElementById('findings');

if(!findings.length){
  fRoot.innerHTML='<p style="color:var(--muted);padding:1rem 0;">No findings. Re-run on a quarterly cadence.</p>';
}else{
  document.getElementById('findings-h').textContent='Findings ('+findings.length+')';
}

['P0','P1','P2'].forEach(function(sev){
  if(!groups[sev].length)return;
  var sec=document.createElement('section');
  sec.className='group';
  var h=document.createElement('div');h.className='group-head';
  h.innerHTML='<h3></h3><span class="gloss"></span>';
  h.querySelector('h3').textContent=sev+' · '+groups[sev].length+(groups[sev].length===1?' finding':' findings');
  h.querySelector('.gloss').textContent=glosses[sev];
  sec.appendChild(h);
  groups[sev].forEach(function(f){sec.appendChild(renderFinding(f))});
  fRoot.appendChild(sec);
});

function renderFinding(f){
  var k=kindFor(f.ruleId);
  var w=document.createElement('article');
  w.className='finding';w.dataset.severity=f.severity;w.dataset.id=f.id;
  fEls.set(f.id,w);
  var loc=f.file+(f.line?':'+f.line:'');
  var head=document.createElement('div');head.className='f-head';
  head.innerHTML='<span class="tag" data-severity="'+f.severity+'">'+f.severity+'</span><p class="f-title"></p><span class="f-loc"></span>';
  head.querySelector('.f-title').textContent=f.title;
  var locEl=head.querySelector('.f-loc');locEl.textContent=loc;locEl.title=loc;
  w.appendChild(head);
  if(f.evidence){
    var d=document.createElement('details');d.className='f-evidence';
    var s=document.createElement('summary');s.textContent='evidence';
    var pre=document.createElement('pre');pre.textContent=f.evidence;
    d.append(s,pre);w.appendChild(d);
  }
  if(f.fixHint){
    var h=document.createElement('p');h.className='f-hint';h.textContent=f.fixHint;w.appendChild(h);
  }
  var ctls=document.createElement('div');ctls.className='controls';
  [['Fix now','fix'],['Defer','defer'],['Dismiss','dismiss']].forEach(function(pair){
    var b=document.createElement('button');b.type='button';b.className='ctl';b.textContent=pair[0];b.dataset.choice=pair[1];b.setAttribute('aria-pressed','false');
    b.addEventListener('click',function(){choose(f,k,pair[1],w)});
    ctls.appendChild(b);
  });
  w.appendChild(ctls);
  var det=document.createElement('div');det.className='f-detail';w.appendChild(det);
  return w;
}

function choose(f,k,c,w){
  w.querySelectorAll('.ctl').forEach(function(b){b.setAttribute('aria-pressed',b.dataset.choice===c?'true':'false')});
  w.dataset.decided='true';w.dataset.decision=c;
  var det=w.querySelector('.f-detail');det.innerHTML='';det.classList.add('is-open');
  var st={choice:c,kind:k,payload:{}};
  if(c==='fix'){
    var labels={
      anchor:'Anchored rewrite',
      'add-or-remove-script':'Replacement command or leave blank to remove',
      'split-or-move':'Target file for the overflow',
      'create-or-fix-link':'New link target or leave blank to create at original',
      'add-frontmatter':'Skill description to set',
      'rewrite-description':'New skill description',
      'populate-section':'Bullet content to add',
      review:'Notes (optional)'
    };
    addInput(det,labels[k]||'Notes',f.suggestedFix||'',function(v){st.payload.value=v;refresh()});
    st.payload.value=f.suggestedFix||'';
    addInput(det,'Comment for the agent (optional)','',function(v){st.payload.comment=v;refresh()},true);
  }else if(c==='defer'){
    addInput(det,'Optional note',' ',function(v){st.payload.reason=v.trim();refresh()});
  }else{
    addInput(det,'Reason for dismissing','',function(v){st.payload.reason=v;refresh()});
  }
  decisions.set(f.id,Object.assign({},st,{finding:f}));
  refresh();
}

function addInput(det,label,init,oninput,multi){
  var l=document.createElement('label');l.textContent=label;
  var i=document.createElement(multi?'textarea':'input');
  if(!multi)i.type='text';
  if(multi)i.rows=2;
  i.value=init;
  i.addEventListener('input',function(){oninput(i.value)});
  det.append(l,i);
}

function undo(id){
  decisions.delete(id);
  var w=fEls.get(id);
  if(w){
    delete w.dataset.decided;delete w.dataset.decision;
    w.querySelectorAll('.ctl').forEach(function(b){b.setAttribute('aria-pressed','false')});
    var det=w.querySelector('.f-detail');if(det){det.innerHTML='';det.classList.remove('is-open')}
  }
  refresh();
}

var aRoot=document.getElementById('actions-list'),cEl=document.getElementById('counter'),gen=document.getElementById('gen');

function refresh(){
  cEl.textContent=decisions.size+' of '+findings.length+' decided';
  aRoot.innerHTML='';
  decisions.forEach(function(d){
    var li=document.createElement('li');li.className='action';
    var k=document.createElement('span');k.className='action-kind';k.textContent=d.choice;
    var b=document.createElement('div');b.className='action-body';
    var s=document.createElement('strong');s.textContent=d.finding.title;b.appendChild(s);
    var fl=document.createElement('div');fl.className='a-file';
    var loc=d.finding.file+(d.finding.line?':'+d.finding.line:'');
    fl.textContent=loc;fl.title=loc;b.appendChild(fl);
    var note=d.choice==='fix'?d.payload.value:d.payload.reason;
    if(note){
      var r=document.createElement('div');r.className='a-res'+(d.choice==='fix'?'':' is-note');
      r.textContent=(d.choice==='fix'?'→ ':'')+note;b.appendChild(r);
    }
    if(d.choice==='fix'&&d.payload.comment){
      var n=document.createElement('div');n.className='a-res is-note';
      n.textContent=d.payload.comment;b.appendChild(n);
    }
    var u=document.createElement('button');u.className='action-undo';u.type='button';u.textContent='undo';
    u.addEventListener('click',function(){undo(d.finding.id)});
    li.append(k,b,u);aRoot.appendChild(li);
  });
  gen.disabled=decisions.size===0;
}

// generate remediation.md
function buildMd(){
  var L=[],now=new Date().toISOString();
  L.push('---','generated: '+now,'source-audit: '+(meta.auditFile||('docs/context-audit-'+meta.date+'.md')),'project: '+(meta.project||'unknown'),'groundwork-remediation: v1','---','','# Remediation plan','');
  var bk={fix:[],defer:[],dismiss:[]};
  decisions.forEach(function(d){bk[d.choice].push(d)});
  if(bk.fix.length){L.push('## To apply','');bk.fix.forEach(function(d){emitFix(L,d)})}
  if(bk.defer.length){L.push('## Deferred','');bk.defer.forEach(function(d){emitNote(L,d,'deferred')})}
  if(bk.dismiss.length){L.push('## Dismissed','');bk.dismiss.forEach(function(d){emitNote(L,d,'dismissed')})}
  return L.join('\n');
}

function emitFix(L,d){
  var f=d.finding,v=d.payload.value||'';
  L.push('### '+f.title);
  L.push('- finding-id: '+f.ruleId);
  L.push('- file: '+f.file);
  if(f.line)L.push('- line: '+f.line);
  switch(d.kind){
    case'anchor':
      if(f.evidence)L.push('- original: '+JSON.stringify(f.evidence));
      if(v)L.push('- new: '+JSON.stringify(v));
      L.push('- action: replace-line');break;
    case'add-or-remove-script':
      L.push('- command: '+JSON.stringify(f.evidence||''));
      L.push('- action: '+(v?'replace':'remove'));
      if(v)L.push('- replacement: '+JSON.stringify(v));break;
    case'populate-section':
      L.push('- action: append-to-section');
      if(v)L.push('- additions:'),v.split('\n').map(function(x){return x.trim()}).filter(Boolean).forEach(function(a){L.push('  - '+JSON.stringify(a))});
      break;
    case'split-or-move':
      L.push('- action: split-to-target');if(v)L.push('- target: '+v);break;
    case'create-or-fix-link':
      L.push('- action: '+(v?'rewrite-link':'create-target'));if(v)L.push('- new-target: '+v);break;
    case'add-frontmatter':
      L.push('- action: add-frontmatter');if(v)L.push('- description: '+JSON.stringify(v));break;
    case'rewrite-description':
      L.push('- action: rewrite-description');if(v)L.push('- description: '+JSON.stringify(v));break;
    default:
      L.push('- action: manual-review');if(v)L.push('- notes: '+JSON.stringify(v));
  }
  if(d.payload.comment)L.push('- comment: '+JSON.stringify(d.payload.comment));
  L.push('');
}
function emitNote(L,d,label){
  var f=d.finding;
  L.push('### '+f.title);
  L.push('- finding-id: '+f.ruleId);
  L.push('- file: '+f.file);
  if(f.line)L.push('- line: '+f.line);
  L.push('- status: '+label);
  if(d.payload.reason)L.push('- reason: '+JSON.stringify(d.payload.reason));
  L.push('');
}

gen.addEventListener('click',function(){
  var md=buildMd(),blob=new Blob([md],{type:'text/markdown;charset=utf-8'}),url=URL.createObjectURL(blob);
  var a=document.createElement('a');
  a.href=url;a.download='audit-remediation-'+(meta.date||new Date().toISOString().slice(0,10))+'.md';
  document.body.appendChild(a);a.click();a.remove();
  setTimeout(function(){URL.revokeObjectURL(url)},0);
});

// theme persisted
var KEY='gw-audit-theme',tBtn=document.querySelector('[data-theme-toggle]');
function setTheme(t){document.documentElement.setAttribute('data-theme',t);tBtn.textContent=t==='dark'?'Light mode':'Dark mode';try{localStorage.setItem(KEY,t)}catch{}}
var init='light';try{var s=localStorage.getItem(KEY);if(s==='light'||s==='dark')init=s}catch{}
setTheme(init);
tBtn.addEventListener('click',function(){setTheme(document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark')});

// print
document.querySelector('[data-print]').addEventListener('click',function(){window.print()});

})();
</script>
</body>
</html>
