#!/usr/bin/env bash
# .context/hooks/check-context.sh
# Pre-commit hook that prevents context-file drift.
# Generated by groundwork verify. Tailor to your stack.

set -e

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_files="$(git diff --cached --name-only)"

# --- Rule 1: package.json change must be reflected in CLAUDE.md ----------------------
# If the package manager changed, the context files lie. Fail fast.
if echo "$staged_files" | grep -q "^package.json$"; then
  if [ -f package.json ]; then
    pkg_mgr_full="$(node -e "console.log(require('./package.json').packageManager || '')" 2>/dev/null || true)"
    pkg_mgr="${pkg_mgr_full%%@*}"
    if [ -n "$pkg_mgr" ] && [ -f CLAUDE.md ] && ! grep -qi "$pkg_mgr" CLAUDE.md; then
      echo "context-check: package.json declares packageManager=$pkg_mgr but CLAUDE.md does not mention it."
      echo "  Run: groundwork document"
      exit 1
    fi
  fi
fi

# --- Rule 2: conventions change must regenerate per-harness files --------------------
if echo "$staged_files" | grep -q "^\.context/conventions\.md$"; then
  regenerated=false
  for f in CLAUDE.md AGENTS.md .github/copilot-instructions.md; do
    if echo "$staged_files" | grep -q "^${f}$"; then
      regenerated=true
      break
    fi
  done
  if echo "$staged_files" | grep -q "^\.cursor/rules/"; then
    regenerated=true
  fi
  if [ "$regenerated" = "false" ]; then
    echo "context-check: .context/conventions.md changed but no per-harness files were regenerated."
    echo "  Run: groundwork document"
    exit 1
  fi
fi

# --- Rule 3: Large commits should reference an ADR or include one ---------------------
# If a commit touches many files, it usually represents a decision worth recording.
# Warn if no ADR is added in this commit AND no existing ADR is referenced in the message.
# Bypass with `git commit --no-verify` if the heuristic is wrong for this commit.
file_count=$(echo "$staged_files" | grep -cE '\.(ts|tsx|js|jsx|py|rs|go|java|kt|rb|php|sql)$' || true)
threshold=5  # tune for your repo
if [ "$file_count" -gt "$threshold" ]; then
  adr_added=$(echo "$staged_files" | grep -cE '^docs/decisions/[0-9]{4}-.+\.md$' || true)
  commit_msg_file="${1:-.git/COMMIT_EDITMSG}"
  adr_referenced=0
  if [ -f "$commit_msg_file" ]; then
    if grep -qiE '(ADR-?[0-9]{4}|docs/decisions/[0-9]{4})' "$commit_msg_file"; then
      adr_referenced=1
    fi
  fi
  if [ "$adr_added" -eq 0 ] && [ "$adr_referenced" -eq 0 ]; then
    echo "context-check: This commit changes $file_count source files but does not add or reference an ADR."
    echo "  If a decision was made here, capture it: groundwork adr"
    echo "  If not, add 'no-adr-needed' to the commit message, or run with --no-verify."
    if [ -f "$commit_msg_file" ] && grep -q "no-adr-needed" "$commit_msg_file"; then
      :  # explicit opt-out
    else
      exit 1
    fi
  fi
fi

# --- Rule 4: ADRs must have status set, not 'proposed' for accepted decisions --------
for adr_file in $(echo "$staged_files" | grep -E '^docs/decisions/[0-9]{4}-.+\.md$' || true); do
  if [ -f "$adr_file" ]; then
    if ! grep -qE '^\*\*Status\*\*:\s*(proposed|accepted|superseded|deprecated)' "$adr_file"; then
      echo "context-check: $adr_file does not declare a valid Status."
      echo "  Expected one of: proposed | accepted | superseded by ADR-XXXX | deprecated"
      exit 1
    fi
  fi
done

exit 0
