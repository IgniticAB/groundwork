#!/usr/bin/env sh
# .husky/pre-commit
# Runs the groundwork detector + the local context-check hook on every commit.

# Local drift checks (package.json vs AGENTS.md, ADR coverage, ADR status).
if [ -x .context/hooks/check-context.sh ]; then
  .context/hooks/check-context.sh
fi

# Full anti-pattern scan via the detector. Bypass with `git commit --no-verify`.
npx --yes --no-install @ignitic/groundwork detect --fail-on P0 || \
  npx --yes @ignitic/groundwork detect --fail-on P0
