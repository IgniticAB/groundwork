{
  "name": "context-engineer",
  "version": "0.1.0",
  "description": "Deterministic context-engineering detector. Finds stale CLAUDE.md, missing ADR cross-links, MCP misconfigurations, secrets in repo, and other context-engineering anti-patterns. No LLM required.",
  "keywords": [
    "context-engineering",
    "claude-code",
    "cursor",
    "agents-md",
    "ai-coding",
    "linter",
    "ci"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "context-engineer": "./bin/context-engineer.mjs"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "node --test dist/test"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
