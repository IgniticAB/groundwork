#!/usr/bin/env sh
# .husky/pre-commit
# Runs the context-engineer detector + the local context-check hook on every commit.

# Local drift checks (package.json vs CLAUDE.md, conventions vs per-harness, ADR-coverage).
if [ -x .context/hooks/check-context.sh ]; then
  .context/hooks/check-context.sh
fi

# Full anti-pattern scan via the detector. Bypass with `git commit --no-verify`.
npx --yes --no-install context-engineer detect --fail-on P0 || \
  npx --yes context-engineer detect --fail-on P0
