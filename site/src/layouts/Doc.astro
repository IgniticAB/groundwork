---
import Base from './Base.astro';
import { url, isActive } from '../lib/url';
import { commands } from '../data/commands';
import { foundation } from '../data/foundation';

interface Props {
  title: string;
  description: string;
  /** "commands" | "foundation": controls which sidebar list is active. */
  section: 'commands' | 'foundation';
  /** Repo-relative path to the skill source file. Renders a GitHub link under the H1 when set. */
  sourceFile?: string;
  /** Repo-relative paths to related template files or directories (trailing `/` for a dir). */
  templateFiles?: string[];
}

const { title, description, section, sourceFile, templateFiles } = Astro.props;
const here = Astro.url.pathname;

const REPO_BASE = 'https://github.com/IgniticAB/groundwork';

function ghHref(path: string): string {
  // Directory paths end with "/" and use GitHub's tree view; files use blob view.
  const kind = path.endsWith('/') ? 'tree' : 'blob';
  const trimmed = path.endsWith('/') ? path.slice(0, -1) : path;
  return `${REPO_BASE}/${kind}/main/${trimmed}`;
}

const sidebar =
  section === 'commands'
    ? {
        heading: 'Commands',
        indexHref: 'commands/',
        items: commands.map((c) => ({
          href: `commands/${c.slug}/`,
          label: c.name,
          hint: c.oneLiner,
        })),
      }
    : {
        heading: 'Foundation',
        indexHref: 'foundation/',
        items: foundation.map((f) => ({
          href: `foundation/${f.slug}/`,
          label: f.title,
          hint: f.oneLiner,
        })),
      };
---

<Base title={title} description={description}>
  <div class="doc">
    <aside class="doc-sidebar" aria-label={`${sidebar.heading} navigation`}>
      <div class="doc-sidebar-inner">
        <a
          href={url(sidebar.indexHref)}
          class:list={['doc-sidebar-heading', isActive(here, sidebar.indexHref) && !isActive(here, sidebar.items[0].href) ? 'is-current' : '']}
        >
          {sidebar.heading}
        </a>
        <ul class="doc-sidebar-list">
          {sidebar.items.map((item) => (
            <li>
              <a
                href={url(item.href)}
                class:list={['doc-sidebar-link', isActive(here, item.href) ? 'is-current' : '']}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </aside>

    <article class="doc-article">
      <h1 class="doc-title">{title}</h1>
      {(sourceFile || (templateFiles && templateFiles.length > 0)) && (
        <div class="doc-source">
          {sourceFile && (
            <a class="doc-chip doc-chip--source" href={ghHref(sourceFile)} target="_blank" rel="noopener">
              <span class="doc-chip-path">{sourceFile}</span>
              <span class="doc-chip-ext" aria-hidden="true">↗</span>
            </a>
          )}
          {templateFiles?.map((path) => (
            <a class="doc-chip doc-chip--template" href={ghHref(path)} target="_blank" rel="noopener">
              <span class="doc-chip-path">{path}</span>
              <span class="doc-chip-ext" aria-hidden="true">↗</span>
            </a>
          ))}
        </div>
      )}
      <slot />
    </article>
  </div>

  <style is:global>
    .doc {
      max-width: var(--doc-max-width);
      margin: 0 auto;
      padding: 2.5rem var(--gutter) 4rem;
      display: grid;
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 3rem;
      align-items: start;
    }

    .doc-sidebar {
      position: sticky;
      top: 2rem;
      align-self: start;
      font-size: 0.92rem;
    }
    .doc-sidebar-inner {
      border-left: 1px solid var(--rule);
      padding-left: 1rem;
    }
    .doc-sidebar-heading {
      display: block;
      font-size: 0.92rem;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 0.8rem;
      text-decoration: none;
      letter-spacing: -0.005em;
    }
    .doc-sidebar-heading:hover { color: var(--ember-ink); }
    .doc-sidebar-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.05rem;
    }
    .doc-sidebar-link {
      display: flex;
      align-items: center;
      min-height: 40px;
      padding: 0.35rem 0;
      color: var(--muted);
      text-decoration: none;
      border-left: 2px solid transparent;
      margin-left: -1rem;
      padding-left: 1rem;
      transition: color 160ms var(--ease-out-quart),
                  border-color 160ms var(--ease-out-quart);
    }
    .doc-sidebar-link:hover {
      color: var(--ink);
    }
    .doc-sidebar-link.is-current {
      color: var(--ink);
      font-weight: 600;
      border-left-color: var(--ember);
    }

    .doc-article { min-width: 0; }
    .doc-article > p:first-of-type,
    .doc-article > .doc-lede {
      font-size: 1.15rem;
      line-height: 1.6;
      color: var(--ink-soft);
    }
    .doc-title { margin-bottom: 0.6rem; }

    .doc-source {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin: 0 0 1.75rem;
      font-family: var(--mono);
      font-size: 0.78rem;
      letter-spacing: 0.02em;
    }
    .doc-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      color: var(--muted);
      text-decoration: none;
      padding: 0.2rem 0.55rem;
      border: 1px solid var(--rule);
      border-radius: 999px;
      transition: color 180ms var(--ease-out-quart),
                  border-color 180ms var(--ease-out-quart),
                  background 180ms var(--ease-out-quart);
    }
    .doc-chip--source .doc-chip-path { font-weight: 600; }
    .doc-chip--template {
      background: var(--bg-soft);
    }
    .doc-chip:hover {
      color: var(--ember-ink);
      border-color: var(--ember);
      background: var(--ember-soft);
    }
    .doc-chip-ext {
      font-size: 0.85em;
      opacity: 0.7;
      transition: transform 180ms var(--ease-out-quart);
    }
    .doc-chip:hover .doc-chip-ext {
      transform: translate(1px, -1px);
      opacity: 1;
    }

    @media (max-width: 880px) {
      .doc {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
      .doc-sidebar {
        position: static;
      }
      .doc-sidebar-inner {
        border-left: none;
        border-top: 1px solid var(--rule);
        border-bottom: 1px solid var(--rule);
        padding: 1rem 0;
      }
      .doc-sidebar-list {
        flex-direction: row;
        flex-wrap: wrap;
        gap: 0.25rem 1rem;
      }
      .doc-sidebar-link {
        margin-left: 0;
        padding-left: 0;
        border-left: none;
        border-bottom: 2px solid transparent;
      }
      .doc-sidebar-link.is-current {
        border-left: none;
        border-bottom-color: var(--ember);
      }
    }
  </style>
</Base>
