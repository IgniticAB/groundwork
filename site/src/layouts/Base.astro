---
import { url } from '../lib/url';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** When true, suppresses the global side padding for full-bleed hero pages. */
  fullBleed?: boolean;
}

const { title, description, fullBleed = false } = Astro.props;
const fullTitle = title === 'Groundwork' ? title : `${title} · Groundwork`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={url('favicon.svg')} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#f3f2f2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1c1a17" media="(prefers-color-scheme: dark)" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wdth,wght@12..96,75..100,400..800&display=swap"
    />
    <title>{fullTitle}</title>
  </head>
  <body class:list={[fullBleed ? 'is-full-bleed' : '']}>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />

    <style is:global>
      :root {
        /* palette: Ignitic-aligned amber-on-gray.
           Hue family ~60 (gold-amber), distinct from cream-coral SaaS defaults.
           Flipping tokens are redefined in the prefers-color-scheme: dark block.
           Fixed tokens stay constant across modes. */
        --bg: #f3f2f2;               /* Ignitic warm-near-white */
        --bg-soft: #e9e6e3;          /* raised, soft taupe */
        --ink: #181615;              /* Ignitic warm near-black */
        --ink-soft: #292524;
        --muted: #6a635e;            /* warm gray, AA on bg and bg-soft */
        --rule: #d4d0cf;             /* Ignitic hairline */
        --rule-soft: #ddd9d6;
        --code-bg: #ebe8e5;
        --code-ink: #292524;
        --ember-soft: #f5e7d0;       /* pale amber wash */
        --ember-ink: #8a4d04;        /* deep amber-brown for emphasis text */
        --surface-feature: #181615;  /* closing/found-lead; flips to raised-dark in dark mode */

        /* fixed across modes: brand identity colours and always-dark surfaces */
        --cream: #fff9ec;
        --ember: #d87708;            /* Ignitic bright amber, brand mark / accents */
        --ember-deep: #a85d01;       /* hero drench, AA body with cream */
        --ember-glow: #ffa14b;       /* spark on dark surfaces, primary CTA bg */
        --surface-dark: #181615;     /* terminal-style: tree, cmd-block, skip-link */

        /* layout */
        --max-width: 760px;
        --doc-max-width: 1140px;
        --hero-max-width: 1280px;
        --gutter: 1.5rem;

        /* motion */
        --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
        --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);

        /* type */
        --display: 'Bricolage Grotesque', 'Söhne Breit', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
        --sans: 'Bricolage Grotesque', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
        --mono: ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #1c1a17;             /* warm dark, slight amber tint */
          --bg-soft: #29251c;
          --ink: #f3ede1;            /* warm cream-tinted text */
          --ink-soft: #d4cab8;
          --muted: #a39787;
          --rule: #3a342d;
          --rule-soft: #2d2823;
          --code-bg: #29251c;
          --code-ink: #f3ede1;
          --ember-soft: #3a2a14;     /* dark amber wash for callouts */
          --ember-ink: #ffa14b;      /* bright amber for emphasis on dark */
          --surface-feature: #2e2a1f;
        }
        /* Light text on dark reads heavier; trim body weight a touch. */
        body { font-weight: 380; }
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--sans);
        font-size: 17px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        font-variation-settings: "opsz" 14;
      }
      body { overflow-x: clip; }

      ::selection { background: var(--ember-soft); color: var(--ember-ink); }

      /* focus management */
      :focus { outline: none; }
      :focus-visible {
        outline: 2px solid var(--ember-ink);
        outline-offset: 3px;
      }
      .btn:focus-visible,
      .btn--primary:focus-visible,
      .btn--ghost:focus-visible {
        outline-offset: 4px;
      }
      /* Dark and ember surfaces invert the outline colour */
      .hero-band :focus-visible,
      .closing :focus-visible,
      .tree :focus-visible,
      .found-lead:focus-visible,
      .found-lead :focus-visible {
        outline-color: var(--cream);
      }
      main:focus { outline: none; }

      /* skip link: present in the DOM, painted only on focus */
      .skip-link {
        position: absolute;
        top: 0;
        left: 1rem;
        transform: translateY(-150%);
        background: var(--surface-dark);
        color: var(--cream);
        padding: 0.7rem 1rem;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.92rem;
        z-index: 1000;
        border-radius: 0 0 8px 8px;
        transition: transform 180ms var(--ease-out-quart);
      }
      .skip-link:focus-visible,
      .skip-link:focus {
        transform: translateY(0);
        outline: 2px solid var(--ember-glow);
        outline-offset: 2px;
      }

      a {
        color: var(--ink);
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
        text-decoration-color: var(--rule);
        transition: text-decoration-color 120ms ease, color 120ms ease;
      }
      a:hover {
        text-decoration-color: var(--ember);
        color: var(--ember-ink);
      }
      .nav-link, .footer a, .footer-brand { text-decoration: none; }

      h1, h2, h3, h4 {
        font-family: var(--display);
        line-height: 1.05;
        letter-spacing: -0.025em;
        margin: 0;
        color: var(--ink);
        font-variation-settings: "opsz" 32;
        text-wrap: balance;
      }

      p, li {
        text-wrap: pretty;
      }
      h1 {
        font-size: clamp(2.4rem, 5vw, 3.6rem);
        font-weight: 750;
        letter-spacing: -0.03em;
        line-height: 1.02;
        font-variation-settings: "opsz" 48;
      }
      h2 {
        font-size: clamp(1.5rem, 2.6vw, 1.9rem);
        font-weight: 700;
        margin-top: 3.25rem;
        margin-bottom: 0.6rem;
        font-variation-settings: "opsz" 24;
      }
      h3 {
        font-size: 1.1rem;
        font-weight: 650;
        margin-top: 2rem;
        margin-bottom: 0.4rem;
        color: var(--ink-soft);
        font-variation-settings: "opsz" 16;
        letter-spacing: -0.015em;
      }
      h4 {
        font-size: 1rem;
        font-weight: 600;
        color: var(--ink-soft);
        margin-top: 1.5rem;
        letter-spacing: -0.005em;
      }

      .display {
        font-family: var(--display);
        font-weight: 800;
        line-height: 0.88;
        letter-spacing: -0.045em;
        font-variation-settings: "opsz" 96, "wdth" 100;
        color: var(--ink);
      }

      p { margin: 0.85em 0; }

      strong { font-weight: 650; color: var(--ink); }

      em { font-style: italic; color: var(--ink-soft); }

      code {
        font-family: var(--mono);
        font-size: 0.92em;
        background: var(--code-bg);
        color: var(--code-ink);
        padding: 0.1em 0.4em;
        border-radius: 4px;
        border: 1px solid color-mix(in srgb, var(--rule), transparent 35%);
      }
      a code { color: inherit; }

      pre {
        font-family: var(--mono);
        font-size: 0.88rem;
        background: var(--code-bg);
        color: var(--code-ink);
        padding: 1rem 1.2rem;
        border-radius: 8px;
        border: 1px solid var(--rule);
        overflow-x: auto;
        line-height: 1.55;
        margin: 1.5rem 0;
      }
      pre code {
        background: none;
        padding: 0;
        border: 0;
        font-size: inherit;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.6rem 0;
        font-size: 0.94rem;
      }
      th, td {
        text-align: left;
        padding: 0.7rem 0.6rem;
        border-bottom: 1px solid var(--rule);
        vertical-align: top;
      }
      th {
        font-weight: 600;
        color: var(--ink-soft);
        font-size: 0.95rem;
        border-bottom: 1px solid var(--ink-soft);
        letter-spacing: -0.005em;
      }
      td code { font-size: 0.9em; }

      hr {
        border: none;
        border-top: 1px solid var(--rule);
        margin: 3rem 0;
      }

      ul, ol { padding-left: 1.4rem; }
      li { margin: 0.3rem 0; }

      blockquote {
        margin: 1.5rem 0;
        padding: 0.9rem 1.2rem;
        color: var(--ember-ink);
        font-style: italic;
        background: var(--ember-soft);
        border: 1px solid color-mix(in srgb, var(--ember), transparent 70%);
        border-radius: 8px;
      }

      /* container */
      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 3.5rem var(--gutter) 5rem;
      }
      .container--wide {
        max-width: var(--doc-max-width);
      }

      /* nav */
      .nav {
        max-width: var(--doc-max-width);
        margin: 0 auto;
        padding: 1.4rem var(--gutter) 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        font-size: 0.95rem;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-weight: 650;
        letter-spacing: -0.01em;
        color: var(--ink);
        text-decoration: none;
      }
      .brand:hover { color: var(--ember-ink); }
      .brand-mark {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: var(--ember);
        box-shadow: 0 0 0 3px var(--ember-soft);
        flex-shrink: 0;
      }
      .nav-links {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.25rem;
      }
      .nav-link {
        color: var(--muted);
        font-weight: 500;
        position: relative;
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        padding: 0 0.1rem;
      }
      .nav-link:hover { color: var(--ink); }
      .nav-link.is-active {
        color: var(--ink);
      }
      .nav-link.is-active::after {
        content: '';
        position: absolute;
        left: 0.1rem;
        right: 0.1rem;
        bottom: 8px;
        height: 2px;
        background: var(--ember);
        border-radius: 2px;
      }
      .nav-link--ext::after { content: ' ↗'; opacity: 0.5; }

      /* footer */
      .footer {
        max-width: var(--doc-max-width);
        margin: 4rem auto 0;
        padding: 3rem var(--gutter) 2rem;
        border-top: 1px solid var(--rule);
        color: var(--muted);
        font-size: 0.92rem;
      }
      .footer-inner {
        display: grid;
        grid-template-columns: 1.4fr 1fr 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
      }
      .footer-block { display: flex; flex-direction: column; gap: 0.4rem; }
      .footer-heading {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: 0.35rem;
        letter-spacing: -0.005em;
      }
      .footer-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 650;
        color: var(--ink);
      }
      .footer-tag {
        margin: 0.4rem 0 0;
        color: var(--muted);
        max-width: 26ch;
        font-size: 0.88rem;
        line-height: 1.5;
      }
      .footer a { color: var(--muted); }
      .footer a:hover { color: var(--ember-ink); }
      .footer-base {
        padding-top: 1.5rem;
        border-top: 1px solid var(--rule);
        color: var(--muted);
        font-size: 0.85rem;
      }

      /* hero shared */
      .hero {
        padding-top: 1.5rem;
        margin-bottom: 3rem;
      }
      .hero h1 { margin-bottom: 1rem; }
      .hero .lede {
        font-size: 1.25rem;
        line-height: 1.55;
        color: var(--ink-soft);
        margin: 0 0 1.8rem;
        max-width: 38ch;
      }

      /* install command block */
      .cmd-block {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        background: var(--surface-dark);
        color: var(--cream);
        padding: 0.95rem 1.15rem;
        border-radius: 10px;
        font-family: var(--mono);
        font-size: 0.95rem;
        max-width: 100%;
        overflow-x: auto;
      }
      .cmd-block::before {
        content: '$';
        color: var(--ember-glow);
        font-weight: 600;
        flex-shrink: 0;
      }

      /* hero band: full-bleed ember drench */
      .hero-band {
        background: var(--ember-deep);
        color: var(--cream);
        margin: 0;
        padding-block: clamp(3rem, 7vw, 6rem);
        position: relative;
        overflow: hidden;
      }
      .hero-band::after {
        content: '';
        position: absolute;
        inset: auto 0 0 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255, 249, 236, 0.18), transparent);
      }
      .hero-band a { color: var(--cream); text-decoration-color: rgba(255, 249, 236, 0.4); }
      .hero-band a:hover { color: var(--cream); text-decoration-color: var(--cream); }
      .hero-band .cmd-block { background: rgba(22, 22, 20, 0.55); color: var(--cream); border: 1px solid rgba(255, 249, 236, 0.18); }
      .hero-band .cmd-block::before { color: var(--ember-glow); }

      /* callout */
      .callout {
        margin: 1.8rem 0;
        padding: 1rem 1.2rem;
        border: 1px solid var(--rule);
        border-radius: 8px;
        background: var(--bg-soft);
      }
      .callout--ember {
        border-color: color-mix(in srgb, var(--ember), transparent 60%);
        background: var(--ember-soft);
      }
      .callout--mute {
        background: var(--bg);
        border-color: var(--rule);
      }
      .callout-label {
        font-size: 0.92rem;
        font-weight: 600;
        color: var(--ember-ink);
        margin-bottom: 0.35rem;
        letter-spacing: -0.005em;
      }
      .callout--mute .callout-label { color: var(--muted); }
      .callout-body p:first-child { margin-top: 0; }
      .callout-body p:last-child { margin-bottom: 0; }

      /* prev/next */
      .pager {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin: 3rem 0 0;
        padding-top: 2rem;
        border-top: 1px solid var(--rule);
      }
      .pager a {
        display: block;
        padding: 1rem 1.1rem;
        border: 1px solid var(--rule);
        border-radius: 8px;
        text-decoration: none;
        transition: border-color 120ms ease, background 120ms ease;
        background: var(--bg);
      }
      .pager a:hover {
        border-color: var(--ember);
        background: var(--bg-soft);
        color: var(--ink);
      }
      .pager-label {
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--muted);
        margin-bottom: 0.2rem;
      }
      .pager-title { font-weight: 600; color: var(--ink); }
      .pager-next { text-align: right; }

      /* responsive */
      @media (max-width: 820px) {
        .footer-inner {
          grid-template-columns: 1fr 1fr;
        }
      }
      @media (max-width: 560px) {
        .nav { padding-top: 1rem; flex-wrap: wrap; }
        .nav-links { gap: 1rem; font-size: 0.9rem; }
        .container { padding: 2rem var(--gutter) 3rem; }
        .footer-inner { grid-template-columns: 1fr; gap: 1.5rem; }
        .pager { grid-template-columns: 1fr; }
        .pager-next { text-align: left; }
        h2 { margin-top: 2.5rem; }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
        .featured-card:hover,
        .btn:hover,
        .btn--primary:hover,
        .found-lead:hover,
        .pager a:hover,
        .hero-arrow:hover span,
        .link-arrow:hover span,
        .featured-card:hover .featured-arrow,
        .cmd-link:hover .cmd-arrow,
        .rest-row:hover .rest-arrow,
        .found-rest-row:hover .rest-arrow,
        .found-row:hover .found-row-arrow,
        .found-lead:hover .found-lead-cta .rest-arrow,
        .skip-link {
          transform: none !important;
        }
        .skip-link:focus,
        .skip-link:focus-visible {
          transform: translateY(0) !important;
        }
      }
    </style>
  </body>
</html>
