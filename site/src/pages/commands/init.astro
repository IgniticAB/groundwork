    </li>
    <li>
      <a href={url('foundation/harness-reference/')}>Harness reference</a>.
      Where each harness expects files.
    </li>
    <li>
      <a href={url('blueprint/#contextops')}>2026 Blueprint: ContextOps</a>
    </li>
  </ul>

  <CommandPager slug="init" />
</Doc>
