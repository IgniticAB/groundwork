    .closing-lede {
      color: rgba(255, 249, 236, 0.78);
      font-size: 1.15rem;
      line-height: 1.5;
      margin: 1.2rem 0 1.8rem;
      max-width: 44ch;
    }
    .closing-cta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.85rem 1.2rem;
      border-radius: 10px;
      font-weight: 600;
      font-size: 0.97rem;
      text-decoration: none;
      transition: background 200ms var(--ease-out-quart),
                  color 200ms var(--ease-out-quart),
                  border-color 200ms var(--ease-out-quart),
                  transform 200ms var(--ease-out-quart);
      min-height: 44px;
    }
    .btn--primary {
      background: var(--ember-glow);
      color: var(--ink);
      border: 1px solid var(--ember-glow);
      font-weight: 700;
    }
    .btn--primary:hover {
      background: var(--cream);
      border-color: var(--cream);
      color: var(--ink);
      transform: translateY(-1px);
    }
    .btn--ghost {
      background: transparent;
      color: var(--cream);
      border: 1px solid rgba(255, 249, 236, 0.32);
    }
    .btn--ghost:hover {
      border-color: var(--cream);
      color: var(--cream);
    }
    .btn code {
      background: none;
      padding: 0;
      border: 0;
      font-size: 0.94em;
      color: inherit;
