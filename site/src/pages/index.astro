      margin: 0 0 0.4rem;
      letter-spacing: -0.01em;
    }
    .closing-head {
      font-family: var(--display);
      font-size: clamp(2.4rem, 5vw, 4rem);
      font-weight: 750;
      line-height: 1.02;
      letter-spacing: -0.03em;
      color: var(--cream);
      margin: 0;
      font-variation-settings: "opsz" 64;
