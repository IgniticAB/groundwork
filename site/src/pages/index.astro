---
import Base from '../layouts/Base.astro';
import { url } from '../lib/url';
import { commands } from '../data/commands';
import { foundation } from '../data/foundation';

const title = 'Groundwork';
const description =
  'Context engineering for any LLM. One skill, ten commands, for setting up and maintaining the boring layer that makes the rest actually useful.';

const featuredSlugs = ['init', 'verify', 'audit'];
const featured = featuredSlugs
  .map((s) => commands.find((c) => c.slug === s))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));
const rest = commands.filter((c) => !featuredSlugs.includes(c.slug));

const heroFeature = foundation[0];

// Tree specimen rows. First entry is the root.
const tree = [
  { line: 'your-repo/', note: '' },
  { line: '├── AGENTS.md', note: 'canonical, ~70 lines' },
  { line: '├── CLAUDE.md → AGENTS.md', note: 'symlink' },
  { line: '├── .cursor/rules/main.mdc', note: '5-line pointer' },
  { line: '├── .github/copilot-instructions.md', note: '5-line pointer' },
  { line: '├── .windsurf/rules/main.md', note: '5-line pointer' },
  { line: '├── .context/hooks/check-context.sh', note: 'pre-commit drift' },
  { line: '└── docs/decisions/', note: '' },
  { line: '    ├── README.md', note: '' },
  { line: '    ├── 0001-record-architecture-decisions.md', note: 'the meta-ADR' },
  { line: '    └── negative-space.md', note: 'rejected paths' },
];
---

<Base title={title} description={description}>
  <section class="hero-band hero-band--home">
    <div class="hero-stage">
      <div class="hero-meta">
        <span class="hero-chip">v1.1 · Groundwork</span>
        <span class="hero-divider" aria-hidden="true"></span>
        <span class="hero-status">MIT · works in 50+ harnesses</span>
      </div>

      <h1 class="hero-display display">
        Context is the new code<span class="hero-display-stop" aria-hidden="true"></span>
      </h1>

      <p class="hero-tag">
        Most teams write it once and never touch it. We make it shippable:
        versioned, reviewed, wired to the checks that prove it works.
      </p>

      <div class="hero-cta">
        <button
          type="button"
          class="cmd-block cmd-block--copy"
          data-copy="npx skills add IgniticAB/groundwork"
          aria-label="Copy install command to clipboard"
        >
          <span class="cmd-text">npx skills add IgniticAB/groundwork</span>
          <span class="cmd-state" aria-hidden="true">copy</span>
        </button>
        <div class="hero-cta-links">
          <a class="hero-arrow" href={url('commands/')}>The ten commands<span aria-hidden="true">→</span></a>
          <a class="hero-arrow" href={url('install/')}>Install guide<span aria-hidden="true">→</span></a>
        </div>
      </div>
    </div>

    <div class="hero-ledge" aria-hidden="true">
      <span>Ignite minds.</span>
      <span class="hero-ledge-dot"></span>
      <span>Spark change.</span>
    </div>
  </section>

  <section class="band band--paper">
    <div class="stage">
      <div class="proof-grid">
        <div class="proof-copy">
          <span class="kicker">What you get</span>
          <h2>One command. Real files.</h2>
          <p class="lede">
            <code>groundwork init</code> reads your repo, asks five questions,
            and writes the files every other command assumes exist.
          </p>
          <p>
            One canonical <code>AGENTS.md</code>. A 5-line pointer per harness.
            ADR scaffolding. A pre-commit hook that fails when context drifts
            from the code. No <em>TODO: implement</em>. No 800-line CLAUDE.md.
          </p>
          <a class="link-arrow" href={url('commands/init/')}>
            How <code>init</code> works<span aria-hidden="true">→</span>
          </a>
        </div>

        <figure class="tree" aria-label="Tree of files Groundwork init produces">
          <figcaption class="tree-caption">
            <span class="tree-prompt">$</span>
            <span>groundwork init</span>
          </figcaption>
          <ol class="tree-lines">
            {tree.map((row) => (
              <li class:list={[
                'tree-line',
                row.line.trim().endsWith('/') ? 'tree-line--dir' : '',
                row.line.startsWith('your-repo/') ? 'tree-line--root' : '',
              ]}>
                <code>{row.line}</code>
                {row.note && <span class="tree-note">{row.note}</span>}
              </li>
            ))}
          </ol>
        </figure>
      </div>
    </div>
  </section>

  <section class="band">
    <div class="stage">
      <header class="band-head">
        <div>
          <span class="kicker">The skill</span>
          <h2>Ten commands. Start with three.</h2>
        </div>
        <a class="link-arrow band-head-cta" href={url('commands/')}>
          All commands<span aria-hidden="true">→</span>
        </a>
      </header>

      <div class="featured">
        {featured.map((c, i) => (
          <a class="featured-card" href={url(`commands/${c.slug}/`)}>
            <span class="featured-num">{String(i + 1).padStart(2, '0')}</span>
            <div class="featured-body">
              <div class="featured-name"><code>{c.name}</code></div>
              <p class="featured-line">{c.oneLiner}</p>
              <p class="featured-when">{c.reachFor}</p>
            </div>
            <span class="featured-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>

      <ul class="rest-list">
        {rest.map((c) => (
          <li>
            <a class="rest-row" href={url(`commands/${c.slug}/`)}>
              <code class="rest-name">{c.name}</code>
              <span class="rest-line">{c.oneLiner}</span>
              <span class="rest-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="band band--paper">
    <div class="stage">
      <header class="band-head">
        <div>
          <span class="kicker">The foundation</span>
          <h2>The model underneath.</h2>
        </div>
        <a class="link-arrow band-head-cta" href={url('foundation/')}>
          All seven pages<span aria-hidden="true">→</span>
        </a>
      </header>

      <a class="found-lead" href={url(`foundation/${heroFeature.slug}/`)}>
        <span class="found-num">01</span>
        <h3 class="found-lead-title">{heroFeature.title}</h3>
        <p class="found-lead-line">{heroFeature.oneLiner}</p>
        <span class="found-lead-cta" aria-hidden="true">Read it<span class="rest-arrow">→</span></span>
      </a>
    </div>
  </section>

  <style>
    /* hero ============================================================== */
    .hero-band--home {
      padding-block: clamp(3.5rem, 7vw, 6.5rem);
    }
    .hero-stage {
      max-width: var(--hero-max-width);
      margin: 0 auto;
      padding-inline: var(--gutter);
      position: relative;
    }
    .hero-meta {
      display: flex;
      align-items: center;
      gap: 0.7rem 1rem;
      flex-wrap: wrap;
      color: rgba(255, 249, 236, 0.82);
      font-size: 0.9rem;
      letter-spacing: 0.01em;
      margin-bottom: clamp(1.6rem, 3vw, 2.4rem);
    }
    .hero-chip {
      padding: 0.4rem 0.8rem;
      border: 1px solid rgba(255, 249, 236, 0.32);
      border-radius: 999px;
      font-weight: 500;
      color: var(--cream);
    }
    .hero-divider {
      flex: 1;
      max-width: 4rem;
      height: 1px;
      background: rgba(255, 249, 236, 0.32);
    }
    .hero-status { font-variant-numeric: tabular-nums; }

    .hero-display {
      font-size: clamp(2.6rem, 7vw, 6rem);
      line-height: 0.98;
      margin: 0;
      color: var(--cream);
      letter-spacing: -0.045em;
      font-variation-settings: "opsz" 96, "wdth" 100;
      max-width: 16ch;
      text-wrap: balance;
    }
    .hero-display-stop {
      display: inline-block;
      width: 0.18em;
      height: 0.18em;
      margin-left: 0.08em;
      vertical-align: 0.05em;
      background: var(--ember-glow);
      border-radius: 999px;
      animation: ignite 760ms var(--ease-out-quart) both;
    }
    @keyframes ignite {
      0% {
        transform: scale(0);
        box-shadow: 0 0 0 0 rgba(255, 161, 75, 0);
      }
      55% {
        transform: scale(1.25);
        box-shadow: 0 0 0 0.12em rgba(255, 161, 75, 0.36);
      }
      100% {
        transform: scale(1);
        box-shadow: 0 0 0 0 rgba(255, 161, 75, 0);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-display-stop { animation: none; }
    }

    .hero-tag {
      max-width: 46ch;
      font-size: clamp(1.1rem, 1.4vw, 1.3rem);
      line-height: 1.5;
      color: rgba(255, 249, 236, 0.92);
      margin: clamp(1.4rem, 2.6vw, 2rem) 0 0;
      font-weight: 400;
    }
    .hero-tag em {
      color: var(--cream);
      font-style: italic;
      font-weight: 500;
    }

    .hero-cta {
      margin-top: clamp(2rem, 3vw, 2.6rem);
      display: flex;
      flex-wrap: wrap;
      gap: 1rem 1.6rem;
      align-items: center;
      max-width: 720px;
    }
    .hero-cta .cmd-block {
      flex: 1 1 360px;
      max-width: 460px;
    }
    .hero-cta-links {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem 1.4rem;
    }
    .hero-arrow {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      color: var(--cream);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.97rem;
      border-bottom: 1px solid rgba(255, 249, 236, 0.4);
      padding-bottom: 0.1rem;
      transition: border-color 200ms var(--ease-out-quart),
                  transform 200ms var(--ease-out-quart);
    }
    .hero-arrow span {
      transition: transform 200ms var(--ease-out-quart);
    }
    .hero-arrow:hover {
      border-bottom-color: var(--cream);
    }
    .hero-arrow:hover span { transform: translateX(3px); }

    /* click-to-copy install command */
    button.cmd-block,
    button.cmd-block--copy {
      font: inherit;
      font-family: var(--mono);
      font-size: 0.95rem;
      cursor: pointer;
      text-align: left;
      width: 100%;
    }
    .cmd-block .cmd-text {
      flex: 1 1 auto;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .cmd-block .cmd-state {
      flex: 0 0 auto;
      margin-left: 1rem;
      font-family: var(--sans);
      font-size: 0.74rem;
      font-weight: 500;
      letter-spacing: 0.01em;
      color: rgba(255, 249, 236, 0.55);
      transition: color 160ms var(--ease-out-quart),
                  opacity 160ms var(--ease-out-quart);
    }
    .cmd-block:hover .cmd-state {
      color: var(--ember-glow);
    }
    .cmd-block:focus-visible .cmd-state {
      color: var(--ember-glow);
    }
    .cmd-block[data-state="copied"] .cmd-state {
      color: var(--cream);
    }
    .cmd-block[data-state="copied"]::before {
      color: var(--cream);
    }

    .hero-ledge {
      max-width: var(--hero-max-width);
      margin: clamp(2.8rem, 4vw, 4rem) auto 0;
      padding-inline: var(--gutter);
      display: flex;
      align-items: center;
      gap: 0.6rem;
      color: rgba(255, 249, 236, 0.62);
      font-size: 0.84rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-weight: 500;
    }
    .hero-ledge-dot {
      width: 4px;
      height: 4px;
      border-radius: 999px;
      background: var(--ember-glow);
    }

    /* bands ============================================================ */
    .band {
      padding-block: clamp(3.5rem, 6vw, 5.5rem);
      border-top: 1px solid var(--rule-soft);
    }
    .band--paper { background: var(--bg-soft); }
    .stage {
      max-width: var(--hero-max-width);
      margin: 0 auto;
      padding-inline: var(--gutter);
    }

    .band-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 1.5rem;
      margin-bottom: clamp(2rem, 3.4vw, 2.8rem);
      flex-wrap: wrap;
    }
    .band-head h2 { margin-top: 0.4rem; max-width: 22ch; }
    .band-head-cta { white-space: nowrap; }

    .kicker {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      color: var(--ember-ink);
      font-size: 0.82rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 600;
    }
    .kicker::before {
      content: "";
      width: 1.4rem;
      height: 1px;
      background: var(--ember);
    }

    /* tree specimen =================================================== */
    .proof-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 4vw, 4rem);
      align-items: start;
    }
    .proof-copy h2 { margin-top: 0.4rem; max-width: 18ch; }
    .proof-copy .lede {
      max-width: 38ch;
      margin-top: 1rem;
    }
    .proof-copy p {
      max-width: 42ch;
      margin-top: 1rem;
      color: var(--ink-soft);
    }
    .tree {
      margin: 0;
      padding: 0;
      background: var(--surface-feature);
      color: var(--cream);
      border-radius: 1rem;
      padding: clamp(1.4rem, 2vw, 2rem);
      font-family: var(--mono);
      font-size: 0.84rem;
      line-height: 1.55;
      position: relative;
      overflow: hidden;
    }
    .tree::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(160deg, rgba(255, 161, 75, 0.06), transparent 55%);
      pointer-events: none;
    }
    .tree-caption {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.82rem;
      color: rgba(255, 249, 236, 0.78);
      margin-bottom: 0.9rem;
      padding-bottom: 0.7rem;
      border-bottom: 1px solid rgba(255, 249, 236, 0.12);
    }
    .tree-prompt { color: var(--ember-glow); font-weight: 700; }
    .tree-lines {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .tree-line {
      display: grid;
      grid-template-columns: minmax(0, auto) 1fr;
      gap: 0.7rem 1rem;
      align-items: baseline;
      padding-block: 0.1rem;
    }
    .tree-line code {
      background: transparent;
      color: var(--cream);
      padding: 0;
      font-size: inherit;
      border: none;
    }
    .tree-line--dir code,
    .tree-line--root code {
      color: var(--ember-glow);
    }
    .tree-note {
      color: rgba(255, 249, 236, 0.5);
      font-family: var(--sans);
      font-size: 0.78rem;
      letter-spacing: 0.01em;
    }

    /* shared link arrow */
    .link-arrow {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--ink);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.96rem;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 0.18rem;
      margin-top: 1.6rem;
      transition: border-color 200ms var(--ease-out-quart);
    }
    .link-arrow code {
      background: transparent;
      padding: 0;
      border: none;
      color: inherit;
    }
    .link-arrow span {
      transition: transform 200ms var(--ease-out-quart);
    }
    .link-arrow:hover {
      border-bottom-color: var(--ember);
    }
    .link-arrow:hover span { transform: translateX(3px); }

    /* featured grid ==================================================== */
    .featured {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.2rem;
      margin-bottom: 2.6rem;
    }
    .featured-card {
      display: grid;
      grid-template-columns: auto 1fr auto;
      grid-template-rows: auto auto auto;
      gap: 0.4rem 1rem;
      padding: 1.4rem 1.5rem 1.5rem;
      background: var(--bg);
      border: 1px solid var(--rule);
      border-radius: 0.9rem;
      text-decoration: none;
      color: inherit;
      transition: border-color 200ms var(--ease-out-quart),
                  transform 200ms var(--ease-out-quart);
      position: relative;
    }
    .featured-card:hover {
      border-color: var(--ember);
      transform: translateY(-2px);
    }
    .featured-num {
      grid-row: 1;
      grid-column: 1;
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--muted);
      letter-spacing: 0.05em;
      padding-top: 0.2rem;
    }
    .featured-body { display: contents; }
    .featured-name {
      grid-row: 1;
      grid-column: 2;
    }
    .featured-name code {
      background: transparent;
      border: none;
      padding: 0;
      font-size: 1.1rem;
      font-weight: 650;
      color: var(--ink);
    }
    .featured-arrow {
      grid-row: 1;
      grid-column: 3;
      align-self: start;
      padding-top: 0.3rem;
      color: var(--muted);
      transition: transform 200ms var(--ease-out-quart),
                  color 200ms var(--ease-out-quart);
    }
    .featured-card:hover .featured-arrow {
      transform: translateX(3px);
      color: var(--ember);
    }
    .featured-line {
      grid-row: 2;
      grid-column: 2 / -1;
      margin: 0.4rem 0 0;
      color: var(--ink);
      font-size: 0.98rem;
      line-height: 1.45;
    }
    .featured-when {
      grid-row: 3;
      grid-column: 2 / -1;
      margin: 0.6rem 0 0;
      color: var(--muted);
      font-size: 0.84rem;
      line-height: 1.45;
    }

    /* rest of commands list =========================================== */
    .rest-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      column-gap: 1.4rem;
      row-gap: 0;
      border-top: 1px solid var(--rule);
    }
    .rest-list li {
      border-bottom: 1px solid var(--rule);
    }
    .rest-list li:nth-child(odd) {
      border-right: 1px solid var(--rule);
    }
    .rest-row {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 1.2rem;
      align-items: center;
      padding: 1rem 1.2rem;
      text-decoration: none;
      color: inherit;
      transition: background 160ms var(--ease-out-quart);
    }
    .rest-row:hover { background: var(--bg-soft); }
    .rest-name {
      background: transparent;
      border: none;
      padding: 0;
      font-size: 1rem;
      font-weight: 650;
      color: var(--ink);
      letter-spacing: -0.005em;
    }
    .rest-line {
      color: var(--ink-soft);
      font-size: 0.92rem;
      line-height: 1.4;
    }
    .rest-arrow {
      color: var(--muted);
      transition: transform 200ms var(--ease-out-quart),
                  color 200ms var(--ease-out-quart);
    }
    .rest-row:hover .rest-arrow {
      transform: translateX(3px);
      color: var(--ember);
    }

    /* foundation lead card ============================================ */
    .found-lead {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 1.2rem 2rem;
      padding: clamp(1.6rem, 2.4vw, 2.2rem);
      background: var(--surface-feature);
      color: var(--cream);
      border-radius: 1rem;
      text-decoration: none;
      align-items: center;
      transition: transform 200ms var(--ease-out-quart);
    }
    .found-lead:hover {
      transform: translateY(-2px);
    }
    .found-num {
      font-family: var(--mono);
      font-size: 0.78rem;
      color: var(--ember-glow);
      letter-spacing: 0.05em;
      align-self: start;
      padding-top: 0.4rem;
    }
    .found-lead-title {
      margin: 0;
      font-size: clamp(1.4rem, 2.2vw, 1.8rem);
      font-weight: 700;
      color: var(--cream);
      letter-spacing: -0.02em;
    }
    .found-lead-line {
      margin: 0.6rem 0 0;
      color: rgba(255, 249, 236, 0.78);
      font-size: 1.02rem;
      line-height: 1.5;
      grid-column: 2;
    }
    .found-lead-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--ember-glow);
      font-weight: 600;
      font-size: 0.92rem;
      letter-spacing: 0.01em;
      white-space: nowrap;
    }
    .found-lead-cta .rest-arrow {
      color: var(--ember-glow);
    }
    .found-lead:hover .found-lead-cta .rest-arrow {
      transform: translateX(3px);
    }

    /* responsive ====================================================== */
    @media (max-width: 1000px) {
      .featured { grid-template-columns: 1fr; }
      .proof-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 900px) {
      .rest-list { grid-template-columns: 1fr; }
      .rest-list li:nth-child(odd) { border-right: none; }
      .found-lead {
        grid-template-columns: 1fr;
        gap: 0.8rem;
      }
      .found-lead-line { grid-column: 1; }
    }
    @media (max-width: 560px) {
      .featured-card { padding: 1.2rem; }
      .rest-row { padding: 1rem; }
    }
  </style>

  <script>
    // click-to-copy on the hero install command
    document.querySelectorAll<HTMLElement>('[data-copy]').forEach((el) => {
      el.addEventListener('click', async () => {
        const text = el.dataset.copy;
        if (!text) return;
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          const range = document.createRange();
          range.selectNodeContents(el);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
          return;
        }
        el.setAttribute('data-state', 'copied');
        const state = el.querySelector('.cmd-state');
        const previous = state?.textContent ?? 'copy';
        if (state) state.textContent = 'copied';
        window.setTimeout(() => {
          el.removeAttribute('data-state');
          if (state) state.textContent = previous;
        }, 1800);
      });
    });
  </script>
</Base>
