---
import Base from '../layouts/Base.astro';
import { url } from '../lib/url';
import { commands } from '../data/commands';
import { foundation } from '../data/foundation';

const title = 'Groundwork';
const description =
  'Context engineering for any LLM. One skill, nine commands, for setting up and maintaining the boring layer that makes the rest actually useful.';
---

<Base title={title} description={description}>
  <main class="container container--wide home">
    <section class="hero">
      <span class="hero-eyebrow">v1.1 · Skill + 9 commands</span>
      <h1>Lay the groundwork.<br />The agent does the rest.</h1>
      <p class="lede">
        Context engineering for any LLM. One skill, nine commands. The boring
        part nobody automates is the only part that compounds.
      </p>

      <div class="hero-cta">
        <code class="cmd-block">npx skills add IgniticAB/groundwork</code>
        <a class="hero-link" href={url('install/')}>or read the install guide →</a>
      </div>

      <p class="hero-support">
        Works with Claude Code, Cursor, Codex, Gemini CLI, OpenCode, and
        <a href="https://github.com/vercel-labs/skills#supported-agents">50+ more</a>.
        MIT-licensed. No smoke, no mirrors.
      </p>
    </section>

    <section class="why">
      <div class="why-stack">
        <div>
          <h2>Context is the new code</h2>
          <p>
            In 2026, the bottleneck on AI-assisted engineering is not model
            capability. It is the quality of the context the model sees. Code
            that ships fast but nobody understands accumulates
            <em>cognitive debt</em> — the gap between a system's structure and
            the team's shared theory of how it works.
          </p>
          <p>
            <strong>Groundwork</strong> turns that context into an engineered
            artifact. Versioned. Reviewed. Wired to the verification commands
            that prove it works. No vibes, no monolithic prompt bloat, no
            assumptions about what your agent already knows.
          </p>
          <p>
            <a href={url('blueprint/')}>The 2026 Context Engineering Blueprint →</a>
          </p>
        </div>
        <div class="why-aside">
          <div class="chip chip--ember">Why it exists</div>
          <ul class="why-list">
            <li>
              <strong>Your CLAUDE.md is one source of truth, not five.</strong>
              <span>Cursor, Codex, Copilot — same rules, emitted in each format.</span>
            </li>
            <li>
              <strong>Verification is baked in.</strong>
              <span>The agent self-corrects against your tests. You only review the design.</span>
            </li>
            <li>
              <strong>Decisions outlive the conversation.</strong>
              <span>ADRs with a "Reconsider if" trigger and a negative-space section.</span>
            </li>
            <li>
              <strong>Drift is a build error.</strong>
              <span>A pre-commit hook catches stale context before it ships.</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <section class="commands-preview">
      <div class="section-head">
        <div>
          <h2>The nine commands</h2>
          <p class="section-sub">
            One file per command in the skill. One short page per command on this
            site — the <em>why</em> first, then the <em>how</em>.
          </p>
        </div>
        <a class="section-cta" href={url('commands/')}>All commands →</a>
      </div>

      <div class="cmd-grid">
        {commands.map((c) => (
          <a class="cmd-card" href={url(`commands/${c.slug}/`)}>
            <div class="cmd-card-head">
              <span class="cmd-name"><code>{c.name}</code></span>
              <span class="cmd-arrow" aria-hidden="true">→</span>
            </div>
            <p class="cmd-line">{c.oneLiner}</p>
            <p class="cmd-when"><span>Reach for it when:</span> {c.reachFor}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="foundation-preview">
      <div class="section-head">
        <div>
          <h2>The foundation</h2>
          <p class="section-sub">
            Seven short files load on every invocation. They are the shared
            vocabulary the commands assume you already speak.
          </p>
        </div>
        <a class="section-cta" href={url('foundation/')}>All foundation pages →</a>
      </div>

      <div class="found-grid">
        {foundation.map((f) => (
          <a class="found-card" href={url(`foundation/${f.slug}/`)}>
            <div class="found-title">{f.title}</div>
            <p class="found-line">{f.oneLiner}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="closing">
      <div class="closing-inner">
        <h2>Stop writing context like prose. Start engineering it.</h2>
        <p class="lede">
          Bootstrap a repo in one command. Audit one that already exists. Or
          start with the philosophy and pick your battles.
        </p>
        <div class="closing-cta">
          <a class="btn btn--primary" href={url('install/')}>Install Groundwork</a>
          <a class="btn btn--ghost" href={url('commands/init/')}>See <code>init</code> in detail</a>
          <a class="btn btn--ghost" href={url('foundation/cognitive-debt/')}>Why cognitive debt is the real risk</a>
        </div>
      </div>
    </section>
  </main>

  <style>
    .home .hero h1 {
      max-width: 18ch;
    }
    .hero-cta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.6rem 1.2rem;
      margin-bottom: 1.2rem;
      max-width: 640px;
    }
    .hero-cta .cmd-block { flex: 1 1 380px; }
    .hero-link { font-size: 0.95rem; color: var(--muted); white-space: nowrap; }
    .hero-link:hover { color: var(--ember-ink); }
    .hero-support {
      color: var(--muted);
      font-size: 0.92rem;
      max-width: 60ch;
    }

    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 1.5rem;
      flex-wrap: wrap;
      margin-top: 4rem;
      margin-bottom: 1.4rem;
    }
    .section-head h2 { margin-top: 0; }
    .section-sub {
      color: var(--muted);
      margin: 0.4rem 0 0;
      max-width: 56ch;
    }
    .section-cta {
      color: var(--ember-ink);
      font-weight: 600;
      text-decoration: none;
      font-size: 0.95rem;
      white-space: nowrap;
    }
    .section-cta:hover { color: var(--ember); }

    .why-stack {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: 2.5rem;
      margin-top: 1rem;
    }
    .why-aside .chip { margin-bottom: 1rem; }
    .why-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
    }
    .why-list li {
      padding: 0.9rem 1rem;
      border: 1px solid var(--rule);
      border-radius: 8px;
      background: var(--bg-soft);
      line-height: 1.5;
    }
    .why-list li strong { display: block; margin-bottom: 0.2rem; }
    .why-list li span { color: var(--muted); font-size: 0.94rem; }

    .cmd-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }
    .cmd-card {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding: 1.1rem 1.2rem;
      border: 1px solid var(--rule);
      border-radius: 10px;
      background: var(--bg);
      text-decoration: none;
      color: var(--ink);
      transition: border-color 120ms ease, background 120ms ease, transform 120ms ease;
    }
    .cmd-card:hover {
      border-color: var(--ember);
      background: var(--bg-soft);
      transform: translateY(-1px);
    }
    .cmd-card-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .cmd-name code {
      background: none;
      border: none;
      padding: 0;
      font-size: 1.05rem;
      font-weight: 650;
      color: var(--ink);
    }
    .cmd-arrow {
      color: var(--muted);
      transition: color 120ms ease, transform 120ms ease;
    }
    .cmd-card:hover .cmd-arrow {
      color: var(--ember);
      transform: translateX(2px);
    }
    .cmd-line {
      margin: 0;
      font-size: 0.95rem;
      color: var(--ink-soft);
      line-height: 1.5;
    }
    .cmd-when {
      margin: 0.3rem 0 0;
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.45;
    }
    .cmd-when span {
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.03em;
    }

    .found-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }
    .found-card {
      padding: 1rem 1.1rem;
      border: 1px solid var(--rule);
      border-radius: 8px;
      background: var(--bg);
      text-decoration: none;
      color: var(--ink);
      transition: border-color 120ms ease, background 120ms ease;
    }
    .found-card:hover {
      border-color: var(--ember);
      background: var(--bg-soft);
    }
    .found-title {
      font-weight: 650;
      margin-bottom: 0.25rem;
    }
    .found-line {
      margin: 0;
      font-size: 0.92rem;
      color: var(--muted);
      line-height: 1.5;
    }

    .closing {
      margin-top: 5rem;
      padding: 3rem 2rem;
      background: var(--ember-soft);
      border-radius: 14px;
      border: 1px solid color-mix(in srgb, var(--ember), transparent 70%);
    }
    .closing h2 {
      margin-top: 0;
      color: var(--ember-ink);
      max-width: 22ch;
    }
    .closing .lede { color: var(--ink-soft); }
    .closing-cta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
      margin-top: 1.6rem;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.7rem 1.1rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
      transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
    }
    .btn--primary {
      background: var(--ember);
      color: var(--bg);
      border: 1px solid var(--ember);
    }
    .btn--primary:hover {
      background: var(--ember-ink);
      border-color: var(--ember-ink);
      color: var(--bg);
    }
    .btn--ghost {
      background: var(--bg);
      color: var(--ink);
      border: 1px solid var(--rule);
    }
    .btn--ghost:hover {
      border-color: var(--ember);
      color: var(--ember-ink);
    }
    .btn code {
      background: none;
      padding: 0;
      border: 0;
      font-size: 0.94em;
      color: inherit;
    }

    @media (max-width: 900px) {
      .why-stack { grid-template-columns: 1fr; gap: 1.5rem; }
      .cmd-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 600px) {
      .cmd-grid { grid-template-columns: 1fr; }
      .found-grid { grid-template-columns: 1fr; }
      .closing { padding: 2rem 1.25rem; }
    }
  </style>
</Base>
