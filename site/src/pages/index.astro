    }
    @media (max-width: 560px) {
      .hero-display { font-size: clamp(2.6rem, 13vw, 5.5rem); }
      .hero-divider { display: none; }
      .hero-meta { gap: 0.6rem 0.9rem; font-size: 0.86rem; }
