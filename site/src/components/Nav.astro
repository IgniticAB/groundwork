---
import { url, isActive } from '../lib/url';

const here = Astro.url.pathname;

const links = [
  { label: 'Foundation', href: 'foundation/' },
  { label: 'Install', href: 'install/' },
  { label: 'Flywheel', href: 'flywheel/' },
  { label: 'Commands', href: 'commands/' },
  { label: 'CLI', href: 'cli/' },
  { label: 'Blueprint', href: 'blueprint/' },
];
---

<nav class="nav">
  <a href={url('')} class="brand" aria-label="Groundwork home">
    <span class="brand-mark" aria-hidden="true"></span>
    <span>Groundwork</span>
  </a>
  <div class="nav-links">
    {links.map((l) => (
      <a
        href={url(l.href)}
        class:list={['nav-link', isActive(here, l.href) ? 'is-active' : '']}
      >
        {l.label}
      </a>
    ))}
    <a class="nav-link nav-link--ext" href="https://github.com/IgniticAB/groundwork">GitHub</a>
  </div>
</nav>
